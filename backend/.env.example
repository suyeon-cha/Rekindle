PORT=3001
# Optional — if not set, message generation uses templates
ANTHROPIC_API_KEY=sk-ant-...

# Box (Client Credentials Grant — Server Auth, NOT JWT)
BOX_CLIENT_ID=
BOX_CLIENT_SECRET=
BOX_ENTERPRISE_ID=
# Folder ID from box.com/folder/<ID>. Use 0 for service-account root.
BOX_DATA_FOLDER_ID=0

# Shared secret Apify must send as x-ingest-token on POST /ingest/*
INGEST_TOKEN=
